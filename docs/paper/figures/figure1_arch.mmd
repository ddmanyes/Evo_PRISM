graph TD
    classDef gateway fill:#fff3e0,stroke:#ef6c00,stroke-width:2px;
    classDef lake fill:#eceff1,stroke:#37474f,stroke-width:2px;
    classDef agent fill:#e3f2fd,stroke:#1565c0,stroke-width:2px;
    classDef hit fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px;

    Q["User Natural Language & API Request"] --> GW["Adaptive De-duplication & Routing Gateway"]:::gateway

    subgraph Gateway["Adaptive De-duplication & Routing Gateway"]
        r1{L1-tier 3-way RRF Semantic Match}
        r2{L2-tier Existing MCP Tools & SQL}
    end

    GW --> r1

    r1 -->|"Cosine >= 0.88"| L1_Hit["L1 Gold Cache Hit<br/>Sub-second 0-Token Response"]:::hit
    r1 -->|"Miss"| r2
    r2 -->|"Found Existing Tool"| L2_Hit["L2 Silver Cache Hit<br/>Rapid SQL & MCP Tool Execution"]:::hit
    r2 -->|"No Existing Tool"| Agent["Evo_PRISM LLM Agent Brain"]:::agent

    subgraph HELIX["HELIX: Self-Evolving Tool Evolution Loop"]
        adhoc["LLM Ad-hoc Code Generation"]:::agent
        sandbox["Secure Sandbox Isolated Execution"]:::agent
        tools["L2 Active MCP Toolset"]:::hit
    end

    Agent -->|"Generate Analysis Code"| adhoc
    adhoc -->|"Execute isolated"| sandbox
    sandbox -->|"Reuse Count >= 3"| tools
    tools -->|"Auto Code Promotion to MCP (SemVer)"| r2

    subgraph ENGRAM["ENGRAM: Semantic Memory Lakehouse"]
        L1["L1 Gold Cache Storage<br/>(hermes_cache.duckdb)"]:::lake
        L2["L2 Silver Feature Store<br/>(sample_registry & analysis_history)"]:::lake
        L3["L3 Bronze Raw Data<br/>(Read-Only Genomics counts)"]:::lake
    end

    sandbox -->|"Load Read-Only Genomics"| L3
    L3 -->|"Structured Parquet conversion"| L2
    L2 -->|"Auto backfill memory"| L1

    L1_Hit -->|"Read cache"| L1
    L2_Hit -->|"Invoke MCP tool"| L2
    L2_Hit -->|"Cache results backfill"| L1

    L1 -->|"Return response"| Resp["Return Results to User"]:::hit
