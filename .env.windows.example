# Evo_PRISM Windows 環境設定範本
# 複製此檔案為 .env 並填入實際路徑
# cp .env.windows.example .env

# ── 專案根目錄（外接硬碟，改為你的實際磁碟代號）────────────────
BIO_DB_ROOT=D:\bio_DB

# ── llama.cpp 路徑（依你的實際安裝位置調整）──────────────────────
LLAMACPP_BIN=C:\Users\你的使用者名稱\llama.cpp\llama-server.exe
LLAMACPP_MODEL_PATH=C:\Users\你的使用者名稱\llama.cpp\models\bge-m3-Q8_0.gguf
LLAMACPP_BASE_URL=http://localhost:8081/v1

# ── Vision 模型（--local 模式才需要）────────────────────────────
VISION_MODEL_PATH=C:\Users\你的使用者名稱\gemma-4-26B-A4B-it-UD-IQ2_M.gguf
MMPROJ_PATH=C:\Users\你的使用者名稱\mmproj-F16.gguf

# ── venv Python（安裝後自動設定，通常不需手動改）──────────────────
VENV_PYTHON=C:\Users\你的使用者名稱\.venvs\hermes-bio-memory\Scripts\python.exe

# ── 推理後端（claude / google / local）────────────────────────────
INFERENCE_BACKEND=claude

# ── API 金鑰（使用雲端 API 時填入）──────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ── DuckDB 路徑（通常不需修改，自動從 BIO_DB_ROOT 推導）──────────
# DUCKDB_PATH=D:\bio_DB\bio_memory.duckdb
# L1_CACHE_PATH=D:\bio_DB\gold\hermes_cache.duckdb

# ── L3 原始數據（外接硬碟上的唯讀數據）────────────────────────────
# L3_DATA_ROOT=D:\bio_DB\crc_visium_data

# ── Embedding 設定 ───────────────────────────────────────────────
EMBEDDING_PROVIDER=llamacpp
EMBEDDING_MODEL=bge-m3-Q8_0
EMBEDDING_DIM=1024

# ── Web App ──────────────────────────────────────────────────────
WEB_APP_BASE_URL=http://localhost:8000

# ── 控制面板（生產環境請關閉）────────────────────────────────────
DASHBOARD_ACTIONS_ENABLED=false
