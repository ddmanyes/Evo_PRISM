# ============================================================
# Hermes Bio-Memory — 環境變數範本
# 使用方法：cp .env.example .env，然後填入實際值
# ⚠️  .env 不可 commit（已加入 .gitignore）
# ============================================================

# ---- 資料路徑 ----
# 預設留空 → config/settings.py 自動以專案根目錄為 BIO_DB_ROOT。
# 99% 的情境（本機開發、別人 clone）不需設定這 4 個變數。
# 僅當 DB / L3 不在預設位置時才覆蓋，例如：
#   - 主 DB 放在外接磁碟而專案在 ~/projects/
#   - L3 原始數據與專案在不同硬碟（典型生產情境）
# 注意：請勿留下 /Volumes/NO NAME 之類的舊範例值，雲端同步路徑變動會踩雷。
# BIO_DB_ROOT=
# L3_DATA_ROOT=
# DUCKDB_PATH=
# L1_CACHE_PATH=

# ---- 模型路徑 ----
# LLAMACPP_MODEL_PATH=~/llama.cpp/models/bge-m3-Q8_0.gguf

# ---- Claude API（Agent 大腦）----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Embedding（L1 語意快取）----
# 已決定：本機 llama.cpp server + BAAI/bge-m3-Q8_0.gguf（1024-dim，多語含中文）
EMBEDDING_PROVIDER=llamacpp
EMBEDDING_MODEL=bge-m3-Q8_0
EMBEDDING_DIM=1024
LLAMACPP_BASE_URL=http://localhost:8081/v1   # llama-server --embedding --port 8081

# 替代選項（暫不使用，保留範例）
# EMBEDDING_PROVIDER=google
# GOOGLE_API_KEY=...
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIM=1536
# OPENAI_API_KEY=sk-...
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ---- Telegram Bot（Phase 0）----
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=  # 逗號分隔，例如 123456789,987654321

# ---- Linux 伺服器（未來部署）----
LINUX_DB_ROOT=/mnt/space4/bio_lab_db
LINUX_L3_ROOT=/mnt/space4/raw_data

# ---- Web App ----
# WEB_APP_HOST=127.0.0.1      # 改為 0.0.0.0 才會對外開放
# CORS_ORIGINS=               # 預設 localhost:8000；多個用逗號分隔

# ---- 開發設定 ----
LOG_LEVEL=INFO
DRY_RUN=false  # true 時不寫入資料庫（測試用）
