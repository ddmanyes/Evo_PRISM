# ============================================================
# Hermes Bio-Memory — 環境變數範本
# 使用方法：cp .env.example .env，然後填入實際值
# ⚠️  .env 不可 commit（已加入 .gitignore）
# ============================================================

# ---- 資料路徑（本機 macOS）----
BIO_DB_ROOT=/Volumes/NO NAME/bio_DB
L3_DATA_ROOT=/Volumes/NO NAME/bio_DB/crc_visium_data
DUCKDB_PATH=/Volumes/NO NAME/bio_DB/bio_memory.duckdb
L1_CACHE_PATH=/Volumes/NO NAME/bio_DB/gold/hermes_cache.duckdb

# ---- Claude API（Agent 大腦）----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Embedding（L1 語意快取）----
# 已決定：本機 llama.cpp server + BAAI/bge-m3-Q8_0.gguf（1024-dim，多語含中文）
EMBEDDING_PROVIDER=llamacpp
EMBEDDING_MODEL=bge-m3-Q8_0
EMBEDDING_DIM=1024
LLAMACPP_BASE_URL=http://localhost:8081/v1   # llama-server --embedding --port 8081

# 替代選項（暫不使用，保留範例）
# EMBEDDING_PROVIDER=google
# GOOGLE_API_KEY=...
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIM=1536
# OPENAI_API_KEY=sk-...
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ---- Telegram Bot（Phase 0）----
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=  # 逗號分隔，例如 123456789,987654321

# ---- Linux 伺服器（未來部署）----
LINUX_DB_ROOT=/mnt/space4/bio_lab_db
LINUX_L3_ROOT=/mnt/space4/raw_data

# ---- 開發設定 ----
LOG_LEVEL=INFO
DRY_RUN=false  # true 時不寫入資料庫（測試用）
