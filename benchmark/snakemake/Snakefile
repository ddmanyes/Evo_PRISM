# Snakemake benchmark workflow — Evo_PRISM CB1
# Equivalent pipeline task: per-sample QC + aggregate PCA on 98 Kallisto samples.
#
# Run:
#   snakemake --cores 1 --configfile config.yaml         # first run
#   snakemake --cores 1 --configfile config.yaml         # incremental re-run (fast)
#   snakemake --cores 1 --configfile config.yaml --forceall  # forced full rerun
#   snakemake --cores 1 --configfile config.yaml --restart-times 1  # fault tolerance

from pathlib import Path

configfile: "config.yaml"

SAMPLES    = config["samples"]
DATA_DIR   = config["data_dir"]
RESULTS    = config["results_dir"]

# ── Target rule ───────────────────────────────────────────────────────────────
rule all:
    input:
        expand(f"{RESULTS}/qc/{{sample}}_qc.csv", sample=SAMPLES),
        f"{RESULTS}/aggregate_qc.csv",
        f"{RESULTS}/pca.png",

# ── Per-sample QC ─────────────────────────────────────────────────────────────
rule per_sample_qc:
    input:
        abundance = lambda wc: f"{DATA_DIR}/{wc.sample}/abundance.tsv",
        run_info  = lambda wc: f"{DATA_DIR}/{wc.sample}/run_info.json",
    output:
        qc_csv    = f"{RESULTS}/qc/{{sample}}_qc.csv",
    run:
        import json
        import pandas as pd
        from pathlib import Path

        Path(output.qc_csv).parent.mkdir(parents=True, exist_ok=True)

        with open(input.run_info) as fh:
            ri = json.load(fh)

        ab = pd.read_csv(input.abundance, sep="\t")
        total_counts   = float(ab["est_counts"].sum())
        n_detected     = int((ab["est_counts"] > 0).sum())

        row = {
            "sample":           wildcards.sample,
            "n_processed":      ri.get("n_processed", 0),
            "n_pseudoaligned":  ri.get("n_pseudoaligned", 0),
            "p_pseudoaligned":  ri.get("p_pseudoaligned", 0.0),
            "total_counts":     total_counts,
            "n_detected_genes": n_detected,
        }
        pd.DataFrame([row]).to_csv(output.qc_csv, index=False)

# ── Aggregate QC + PCA ────────────────────────────────────────────────────────
rule aggregate_qc:
    input:
        qc_csvs   = expand(f"{RESULTS}/qc/{{sample}}_qc.csv", sample=SAMPLES),
    output:
        agg_csv   = f"{RESULTS}/aggregate_qc.csv",
        pca_plot  = f"{RESULTS}/pca.png",
    run:
        import pandas as pd
        import matplotlib
        matplotlib.use("Agg")
        import matplotlib.pyplot as plt
        from sklearn.preprocessing import StandardScaler
        from sklearn.decomposition import PCA

        dfs = [pd.read_csv(f) for f in input.qc_csvs]
        agg = pd.concat(dfs, ignore_index=True)
        agg.to_csv(output.agg_csv, index=False)

        feat_cols = ["total_counts", "n_detected_genes", "p_pseudoaligned"]
        X  = StandardScaler().fit_transform(agg[feat_cols].fillna(0))
        pc = PCA(n_components=2, random_state=42).fit_transform(X)

        fig, ax = plt.subplots(figsize=(8, 6))
        ax.scatter(pc[:, 0], pc[:, 1], alpha=0.7, s=30)
        ax.set_xlabel("PC1"); ax.set_ylabel("PC2")
        ax.set_title(f"QC PCA — {len(agg)} samples")
        fig.savefig(output.pca_plot, dpi=100, bbox_inches="tight")
        plt.close(fig)
