// Nextflow benchmark config — Evo_PRISM CB1
// Runs on the local executor (single machine).
// For HPC deployment, change executor to 'slurm' or 'sge'.

process {
    executor    = 'local'
    cpus        = 1
    memory      = '4 GB'
    // Windows bind-mounts do not support symlinks; use copy staging instead
    stageInMode = 'copy'
}

// Disable automatic cleanup of work dirs so incremental -resume works correctly
cleanup = false

// Cache fingerprinting: 'lenient' (file size+mtime) or 'deep' (MD5 hash)
// 'deep' is slower but detects content changes; consistent with paper §3 description.
process.cache = 'deep'

report {
    enabled = true
    file    = "benchmark/nextflow/results/nextflow_report.html"
}

timeline {
    enabled = true
    file    = "benchmark/nextflow/results/nextflow_timeline.html"
}
