# DuckDB databases (large binary files)
*.duckdb
*.duckdb.wal

# Parquet data files (large, regenerable from scripts)
silver/
gold/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# 環境變數（含 API keys，絕不 commit）
.env

# 測試覆蓋率
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db
# macOS resource forks（ExFAT 產生）
._*
# Office 臨時鎖檔
~$*

# Runtime logs / status（每次執行都會變，不進 git）
logs/*.log
logs/*_status.json

# 大型數據目錄（L3 原始數據，不進 git）
crc_visium_data/
results_ana/
data_ana/

# Bulk RNA — 數據不進 git（L2 結果與 QC 報告體積大，以路徑記錄即可）
bulk_rna_data/
references/genome/

# Large PDFs and binary documents (keep .md versions only)
references/pdfs/
reports/*.pdf
reports/*.docx
reports/*.tex
*.pdf
*.docx

# uv lock file and venv symlink
uv.lock
.venv

# 分析產出圖檔（路徑記錄於 analysis_history.result_path，圖檔本身不進 git）
results/

# Backup 目錄（家目錄已存，避免誤建在專案內）
bio_db_backups/

# Temp / scratch files
file_info_input.md

# MCP 設定（含本機絕對路徑，不跨機器）
.mcp.json
